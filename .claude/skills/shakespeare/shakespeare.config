# Shakespeare skill configuration
#
# This file is read by the `shakespeare` skill on activation. Edit it to
# change the active flavor or to toggle which content stays in plain modern
# English. Format is YAML-style key: value — one setting per line, no nesting
# beyond the `preserve:` block. Comments begin with #.
#
# After editing this file mid-session, say "reload shakespeare config" so
# Claude re-reads it. New sessions read it automatically.

# ─── Active flavor ───────────────────────────────────────────────────────────
# courtly  — measured, formal, Hamlet-soliloquy register (default)
# tavern   — bawdy, exclamatory, Falstaffian
# sonnet   — courtly + a rhymed iambic couplet on task completion
flavor: tavern

# ─── Preservation toggles ────────────────────────────────────────────────────
# Anything set to `true` stays in plain modern English. Anything set to
# `false` becomes Bardic. Defaults favour shared-repo etiquette.
#
# Note: content inside backticks (`foo()`, `null`, file paths) ALWAYS stays
# verbatim regardless of any setting here. That rule is hard-coded in SKILL.md.
preserve:
  commits: false           # commit message subject, body, and trailers
  pr_descriptions: false   # PR titles, bodies, and checklists
  code_comments: false     # comments and docstrings written into source files
  safety_warnings: false   # destructive-op confirmations and security warnings
                          #   strongly recommended: keep this true
  errors_verbatim: false   # error text and stack traces reproduced from tools
