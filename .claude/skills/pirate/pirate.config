# Pirate skill configuration
#
# This file is read by the `pirate` skill on activation. Edit it to change
# the active flavor or to toggle which content stays in plain modern English.
# Format is YAML-style key: value — one setting per line, no nesting beyond
# the `preserve:` block. Comments begin with #.
#
# After editing this file mid-session, say "reload pirate config" so Claude
# re-reads it. New sessions read it automatically.

# ─── Active flavor ───────────────────────────────────────────────────────────
# scurvy-dog — Treasure Island vintage, gruff but jolly (default)
# captain    — Long John Silver gravitas, measured and commanding
# drunk      — rambunctious tavern register, swaying grammar, more yarrrrs
# shanty     — scurvy-dog + a 4-line sea shanty on task completion
flavor: scurvy-dog

# ─── Preservation toggles ────────────────────────────────────────────────────
# Anything set to `true` stays in plain modern English. Anything set to
# `false` becomes piratey. Defaults favour shared-repo etiquette.
#
# Note: content inside backticks (`foo()`, `null`, file paths) ALWAYS stays
# verbatim regardless of any setting here. That rule is hard-coded in SKILL.md.
#
# Danger combo: setting `flavor: drunk` and `safety_warnings: false` together
# is actively dangerous — destructive-op confirmations read as a drunken
# slur. If you want drunk flavor, leave safety_warnings on.
preserve:
  commits: true           # commit message subject, body, and trailers
  pr_descriptions: true   # PR titles, bodies, and checklists
  code_comments: true     # comments and docstrings written into source files
  safety_warnings: true   # destructive-op confirmations and security warnings
                          #   strongly recommended: keep this true
  errors_verbatim: true   # error text and stack traces reproduced from tools
